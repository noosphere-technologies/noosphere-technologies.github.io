---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Noosphere — Trust Infrastructure for the Agent Economy" description="Decentralized trust overlay for AI agents. C2PA content credentials, DIDs, verifiable credentials, and policy enforcement. The PKI that PKI should have been." />
		<style>
			/* === Page Layout === */
			body {
				margin: 0;
				padding: 0;
				background: #000;
				color: #fff;
				font-family: 'Inter', -apple-system, sans-serif;
				line-height: 1.6;
			}

			/* Grid overlay for retro feel */
			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background-image:
					linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
				background-size: 40px 40px;
				pointer-events: none;
				z-index: 1;
			}

			.page {
				position: relative;
				z-index: 10;
			}

			/* === Navigation === */
			.nav {
				border-bottom: 1px solid #222;
				padding: 1.5rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.nav-brand {
				display: flex;
				align-items: center;
				gap: 1rem;
				text-decoration: none;
				color: #fff;
			}

			.nav-logo {
				height: 36px;
				width: auto;
			}

			.nav-name {
				font-family: 'JetBrains Mono', monospace;
				font-size: 1rem;
				font-weight: 400;
				letter-spacing: -0.02em;
			}

			.nav-links {
				display: flex;
				gap: 2rem;
			}

			.nav-links a {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.875rem;
				color: #888;
				text-decoration: none;
				transition: color 0.15s;
			}

			.nav-links a:hover {
				color: #fff;
			}

			/* === Hero === */
			.hero {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 4rem;
				padding: 6rem 2rem;
				max-width: 1400px;
				margin: 0 auto;
				align-items: center;
			}

			.hero-content h1 {
				font-family: 'JetBrains Mono', monospace;
				font-size: 2.5rem;
				font-weight: 400;
				line-height: 1.2;
				margin: 0 0 1.5rem 0;
				letter-spacing: -0.03em;
			}

			.hero-content p {
				font-size: 1.125rem;
				color: #999;
				margin: 0 0 2rem 0;
				max-width: 500px;
			}

			.hero-cta {
				display: inline-block;
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.875rem;
				padding: 1rem 2rem;
				border: 1px solid #444;
				color: #fff;
				text-decoration: none;
				transition: all 0.15s;
			}

			.hero-cta:hover {
				background: #fff;
				color: #000;
				border-color: #fff;
			}

			.hero-visual {
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.hero-visual img {
				max-width: 100%;
				height: auto;
				filter: grayscale(100%) contrast(1.2);
				opacity: 0.8;
			}

			/* === Problem Section === */
			.section {
				padding: 6rem 2rem;
				border-top: 1px solid #222;
			}

			.section-inner {
				max-width: 1200px;
				margin: 0 auto;
			}

			.section-header {
				margin-bottom: 4rem;
			}

			.section-label {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: #666;
				margin-bottom: 1rem;
			}

			.section-title {
				font-family: 'JetBrains Mono', monospace;
				font-size: 1.75rem;
				font-weight: 400;
				margin: 0;
				max-width: 700px;
			}

			/* === Cards Grid === */
			.cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: #333;
			}

			.card {
				background: #000;
				padding: 2rem;
			}

			.card-icon {
				font-size: 1.5rem;
				margin-bottom: 1rem;
			}

			.card-title {
				font-family: 'JetBrains Mono', monospace;
				font-size: 1rem;
				margin: 0 0 0.5rem 0;
			}

			.card-text {
				font-size: 0.875rem;
				color: #888;
				margin: 0;
			}

			/* === Solution Section === */
			.solution-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 4rem;
				align-items: start;
			}

			.solution-steps {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.step {
				display: grid;
				grid-template-columns: 3rem 1fr;
				gap: 1rem;
				align-items: start;
			}

			.step-number {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.875rem;
				color: #666;
				padding-top: 0.25rem;
			}

			.step-content h3 {
				font-family: 'JetBrains Mono', monospace;
				font-size: 1rem;
				margin: 0 0 0.5rem 0;
			}

			.step-content p {
				font-size: 0.875rem;
				color: #888;
				margin: 0;
			}

			/* === Stack Section === */
			.stack-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1px;
				background: #333;
			}

			.stack-item {
				background: #000;
				padding: 2rem;
				text-align: center;
			}

			.stack-name {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.875rem;
				margin: 0 0 0.25rem 0;
			}

			.stack-desc {
				font-size: 0.75rem;
				color: #666;
				margin: 0;
			}

			/* === Footer === */
			.footer {
				border-top: 1px solid #222;
				padding: 3rem 2rem;
				text-align: center;
			}

			.footer-text {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.75rem;
				color: #666;
				margin: 0;
			}

			.footer-links {
				display: flex;
				justify-content: center;
				gap: 2rem;
				margin-top: 1rem;
			}

			.footer-links a {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.75rem;
				color: #666;
				text-decoration: none;
			}

			.footer-links a:hover {
				color: #fff;
			}

			/* === Responsive === */
			@media (max-width: 1024px) {
				.hero {
					grid-template-columns: 1fr;
					gap: 3rem;
				}

				.hero-visual {
					order: -1;
				}

				.cards {
					grid-template-columns: 1fr;
				}

				.solution-grid {
					grid-template-columns: 1fr;
				}

				.stack-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 640px) {
				.hero-content h1 {
					font-size: 1.75rem;
				}

				.nav {
					flex-direction: column;
					gap: 1rem;
				}

				.stack-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<div class="page">
			<!-- Navigation -->
			<nav class="nav">
				<a href="/" class="nav-brand">
					<img src="/images/logos/black-logo-cropped.png" alt="N" class="nav-logo" />
					<span class="nav-name">Noosphere</span>
				</a>
				<div class="nav-links">
					<a href="/blog">Blog</a>
					<a href="/contact">Contact</a>
					<a href="https://github.com/noosphere-technologies" target="_blank">GitHub</a>
				</div>
			</nav>

			<!-- Hero -->
			<section class="hero">
				<div class="hero-content">
					<h1>Trust infrastructure for the agent economy</h1>
					<p>AI agents operate on unverified context. We provide the cryptographic provenance layer—C2PA credentials, DIDs, verifiable capabilities, and runtime policy enforcement.</p>
					<a href="/contact" class="hero-cta">Get in touch →</a>
				</div>
				<div class="hero-visual">
					<img src="/images/davinci-sphere-2.png" alt="Trust network visualization" />
				</div>
			</section>

			<!-- Problem -->
			<section class="section">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-label">The Problem</p>
						<h2 class="section-title">When Agent A tells Agent B something, how does Agent B know where it came from, who authored it, or if it's been tampered with?</h2>
					</div>
					<div class="cards">
						<div class="card">
							<div class="card-icon">◇</div>
							<h3 class="card-title">Inferred context</h3>
							<p class="card-text">Agents guess where data comes from based on retrieval paths, not cryptographic proof.</p>
						</div>
						<div class="card">
							<div class="card-icon">△</div>
							<h3 class="card-title">Implicit trust</h3>
							<p class="card-text">No mechanism to verify capabilities or authorization across organizational boundaries.</p>
						</div>
						<div class="card">
							<div class="card-icon">○</div>
							<h3 class="card-title">No runtime enforcement</h3>
							<p class="card-text">Policies exist in docs, not in cryptographically-enforced attestations.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Solution -->
			<section class="section">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-label">Our Approach</p>
						<h2 class="section-title">The provenance layer for AI agent context</h2>
					</div>
					<div class="solution-grid">
						<div class="solution-steps">
							<div class="step">
								<span class="step-number">01</span>
								<div class="step-content">
									<h3>Sign under policy</h3>
									<p>Content and context get C2PA credentials with Cedar policy attestations. Every artifact carries proof of origin, authorization, and constraints.</p>
								</div>
							</div>
							<div class="step">
								<span class="step-number">02</span>
								<div class="step-content">
									<h3>Build the trust graph</h3>
									<p>trust.txt declarations create a crawlable web of organizational trust relationships. No central authority—trust emerges from the network.</p>
								</div>
							</div>
							<div class="step">
								<span class="step-number">03</span>
								<div class="step-content">
									<h3>Validate at runtime</h3>
									<p>Before acting on context, agents verify credentials, check trust paths, and evaluate policies. Deterministic, auditable decisions.</p>
								</div>
							</div>
						</div>
						<div class="solution-visual">
							<img src="/images/noosphere-trans.png" alt="Noosphere trust graph" style="max-width: 100%; filter: grayscale(50%);" />
						</div>
					</div>
				</div>
			</section>

			<!-- Stack -->
			<section class="section">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-label">Standards-Based</p>
						<h2 class="section-title">Built on proven specifications, not proprietary protocols</h2>
					</div>
					<div class="stack-grid">
						<div class="stack-item">
							<p class="stack-name">C2PA</p>
							<p class="stack-desc">Content credentials</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">DIDs</p>
							<p class="stack-desc">Decentralized identity</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">VCs</p>
							<p class="stack-desc">Verifiable credentials</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">Cedar</p>
							<p class="stack-desc">Policy language</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">in-toto</p>
							<p class="stack-desc">Supply chain attestations</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">SLSA</p>
							<p class="stack-desc">Build provenance</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">SPIFFE</p>
							<p class="stack-desc">Workload identity</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">DSSE</p>
							<p class="stack-desc">Signature envelopes</p>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="section" style="text-align: center;">
				<div class="section-inner">
					<h2 class="section-title" style="max-width: 600px; margin: 0 auto 2rem;">The PKI that PKI should have been. Built for agents, not browsers.</h2>
					<a href="/contact" class="hero-cta">Start a conversation →</a>
				</div>
			</section>

			<!-- Footer -->
			<footer class="footer">
				<p class="footer-text">© 2026 Noosphere Technologies, Inc.</p>
				<div class="footer-links">
					<a href="/blog">Blog</a>
					<a href="/contact">Contact</a>
					<a href="https://github.com/noosphere-technologies">GitHub</a>
					<a href="https://twitter.com/noospheretech">Twitter</a>
				</div>
			</footer>
		</div>
	</body>
</html>
