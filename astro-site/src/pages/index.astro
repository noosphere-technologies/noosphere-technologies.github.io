---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Noosphere — Trust Infrastructure for the Agent Economy" description="Decentralized trust overlay for AI agents. C2PA content credentials, DIDs, verifiable credentials, and policy enforcement. The PKI that PKI should have been." />
		<style>
			/* === Base === */
			body {
				margin: 0;
				padding: 0;
				background: #0a0a0a;
				color: #fff;
				font-family: 'JetBrains Mono', 'SF Mono', 'Monaco', 'Inconsolata', monospace;
				line-height: 1.6;
				font-weight: 500;
			}

			.page {
				position: relative;
			}

			/* === Navigation === */
			.nav {
				background: #000;
				border-bottom: 2px solid #00d4ff;
				padding: 1.25rem 3rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.nav-brand {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: #fff;
			}

			.nav-logo {
				height: 48px;
				width: auto;
			}

			.nav-name {
				font-size: 1.35rem;
				font-weight: 600;
				letter-spacing: -0.02em;
			}

			.nav-links {
				display: flex;
				gap: 2.5rem;
			}

			.nav-links a {
				font-size: 1.1rem;
				font-weight: 500;
				color: #888;
				text-decoration: none;
				transition: color 0.15s;
			}

			.nav-links a:hover {
				color: #00d4ff;
			}

			/* === Hero === */
			.hero {
				background: #000;
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				gap: 4rem;
				padding: 5rem 3rem;
				align-items: center;
				min-height: 70vh;
			}

			.hero-content h1 {
				font-size: 4.5rem;
				font-weight: 700;
				line-height: 1.05;
				margin: 0 0 1.5rem 0;
				letter-spacing: -0.03em;
			}

			.hero-content h1 span {
				color: #00d4ff;
			}

			.hero-content p {
				font-size: 1.6rem;
				font-weight: 400;
				color: #ccc;
				margin: 0 0 2.5rem 0;
				max-width: 600px;
				line-height: 1.5;
			}

			.hero-cta {
				display: inline-block;
				font-size: 1.2rem;
				padding: 1.2rem 3rem;
				background: #00d4ff;
				color: #000;
				text-decoration: none;
				transition: all 0.15s;
				font-weight: 600;
			}

			.hero-cta:hover {
				background: #00b8e6;
			}

			.hero-visual {
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.hero-visual img {
				max-width: 100%;
				height: auto;
				max-height: 500px;
			}

			/* === Problem Section === */
			.section {
				padding: 5rem 3rem;
				border-top: 2px solid #222;
			}

			.section-dark {
				background: #000;
			}

			.section-inner {
				max-width: 1300px;
				margin: 0 auto;
			}

			.section-header {
				margin-bottom: 3rem;
			}

			.section-label {
				font-size: 1.1rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.15em;
				color: #00d4ff;
				margin-bottom: 0.75rem;
			}

			.section-title {
				font-size: 2.5rem;
				font-weight: 600;
				margin: 0;
				max-width: 900px;
				line-height: 1.3;
			}

			/* === Cards Grid === */
			.cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 3px;
				background: #00d4ff;
			}

			.card {
				background: #0a0a0a;
				padding: 2.5rem;
			}

			.card-icon {
				font-size: 3rem;
				margin-bottom: 1.25rem;
				color: #00d4ff;
			}

			.card-title {
				font-size: 1.6rem;
				font-weight: 600;
				margin: 0 0 0.75rem 0;
			}

			.card-text {
				font-size: 1.25rem;
				font-weight: 400;
				color: #aaa;
				margin: 0;
				line-height: 1.5;
			}

			/* === Solution Section === */
			.solution-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 4rem;
				align-items: center;
			}

			.solution-steps {
				display: flex;
				flex-direction: column;
				gap: 2.5rem;
			}

			.step {
				display: grid;
				grid-template-columns: 5rem 1fr;
				gap: 1.5rem;
				align-items: start;
			}

			.step-number {
				font-size: 3.5rem;
				font-weight: 700;
				color: #00d4ff;
				line-height: 1;
			}

			.step-content h3 {
				font-size: 1.6rem;
				font-weight: 600;
				margin: 0 0 0.5rem 0;
			}

			.step-content p {
				font-size: 1.25rem;
				font-weight: 400;
				color: #aaa;
				margin: 0;
				line-height: 1.5;
			}

			.solution-visual img {
				width: 100%;
				max-width: 450px;
				margin: 0 auto;
				display: block;
			}

			/* === Stack Section === */
			.stack-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 3px;
				background: #00d4ff;
			}

			.stack-item {
				background: #0a0a0a;
				padding: 2.5rem;
				text-align: center;
			}

			.stack-name {
				font-size: 1.6rem;
				font-weight: 600;
				margin: 0 0 0.25rem 0;
			}

			.stack-desc {
				font-size: 1.1rem;
				font-weight: 400;
				color: #888;
				margin: 0;
			}

			/* === CTA Section === */
			.cta-section {
				background: #000;
				padding: 6rem 3rem;
				text-align: center;
				border-top: 2px solid #00d4ff;
			}

			.cta-title {
				font-size: 3rem;
				font-weight: 700;
				margin: 0 0 2rem 0;
				max-width: 800px;
				margin-left: auto;
				margin-right: auto;
				line-height: 1.2;
			}

			/* === Footer === */
			.footer {
				background: #000;
				border-top: 1px solid #222;
				padding: 2rem 3rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.footer-text {
				font-size: 1rem;
				font-weight: 500;
				color: #666;
				margin: 0;
			}

			.footer-links {
				display: flex;
				gap: 2rem;
			}

			.footer-links a {
				font-size: 1rem;
				font-weight: 500;
				color: #666;
				text-decoration: none;
			}

			.footer-links a:hover {
				color: #00d4ff;
			}

			/* === Responsive === */
			@media (max-width: 1024px) {
				.hero {
					grid-template-columns: 1fr;
					gap: 3rem;
					padding: 3rem 2rem;
					min-height: auto;
				}

				.hero-content h1 {
					font-size: 3.5rem;
				}

				.hero-content p {
					font-size: 1.4rem;
				}

				.hero-visual {
					order: -1;
				}

				.hero-visual img {
					max-height: 350px;
				}

				.cards {
					grid-template-columns: 1fr;
				}

				.solution-grid {
					grid-template-columns: 1fr;
				}

				.stack-grid {
					grid-template-columns: repeat(2, 1fr);
				}

				.section {
					padding: 3rem 2rem;
				}

				.nav {
					padding: 1rem 1.5rem;
				}

				.footer {
					flex-direction: column;
					gap: 1rem;
					text-align: center;
				}
			}

			@media (max-width: 640px) {
				.hero-content h1 {
					font-size: 2.75rem;
				}

				.hero-content p {
					font-size: 1.3rem;
				}

				.section-title {
					font-size: 2rem;
				}

				.card-text, .step-content p {
					font-size: 1.15rem;
				}

				.nav {
					flex-direction: column;
					gap: 1rem;
				}

				.stack-grid {
					grid-template-columns: 1fr;
				}

				.cta-title {
					font-size: 2.25rem;
				}
			}
		</style>
	</head>
	<body>
		<div class="page">
			<!-- Navigation -->
			<nav class="nav">
				<a href="/" class="nav-brand">
					<img src="/images/logos/black-logo-cropped.png" alt="N" class="nav-logo" />
					<span class="nav-name">Noosphere Technologies</span>
				</a>
				<div class="nav-links">
					<a href="/blog">Blog</a>
					<a href="/contact">Contact</a>
					<a href="https://github.com/noosphere-technologies" target="_blank">GitHub</a>
				</div>
			</nav>

			<!-- Hero -->
			<section class="hero">
				<div class="hero-content">
					<h1>Trust infrastructure for the <span>agent economy</span></h1>
					<p>AI agents operate on unverified context. We provide the cryptographic provenance layer—C2PA credentials, DIDs, verifiable capabilities, and runtime policy enforcement.</p>
					<a href="/contact" class="hero-cta">Get in touch →</a>
				</div>
				<div class="hero-visual">
					<img src="/images/noosphere-trans.png" alt="Noosphere trust network" />
				</div>
			</section>

			<!-- Problem -->
			<section class="section section-dark">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-label">The Problem</p>
						<h2 class="section-title">When Agent A tells Agent B something, how does Agent B know where it came from, who authored it, or if it's been tampered with?</h2>
					</div>
					<div class="cards">
						<div class="card">
							<div class="card-icon">◇</div>
							<h3 class="card-title">Inferred context</h3>
							<p class="card-text">Agents guess where data comes from based on retrieval paths, not cryptographic proof.</p>
						</div>
						<div class="card">
							<div class="card-icon">△</div>
							<h3 class="card-title">Implicit trust</h3>
							<p class="card-text">No mechanism to verify capabilities or authorization across organizational boundaries.</p>
						</div>
						<div class="card">
							<div class="card-icon">○</div>
							<h3 class="card-title">No runtime enforcement</h3>
							<p class="card-text">Policies exist in docs, not in cryptographically-enforced attestations.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Solution -->
			<section class="section">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-label">Our Approach</p>
						<h2 class="section-title">The provenance layer for AI agent context</h2>
					</div>
					<div class="solution-grid">
						<div class="solution-steps">
							<div class="step">
								<span class="step-number">01</span>
								<div class="step-content">
									<h3>Sign under policy</h3>
									<p>Content and context get C2PA credentials with Cedar policy attestations. Every artifact carries proof of origin, authorization, and constraints.</p>
								</div>
							</div>
							<div class="step">
								<span class="step-number">02</span>
								<div class="step-content">
									<h3>Build the trust graph</h3>
									<p>trust.txt declarations create a crawlable web of organizational trust relationships. No central authority—trust emerges from the network.</p>
								</div>
							</div>
							<div class="step">
								<span class="step-number">03</span>
								<div class="step-content">
									<h3>Validate at runtime</h3>
									<p>Before acting on context, agents verify credentials, check trust paths, and evaluate policies. Deterministic, auditable decisions.</p>
								</div>
							</div>
						</div>
						<div class="solution-visual">
							<img src="/images/noosphere-trans.png" alt="Noosphere trust graph" />
						</div>
					</div>
				</div>
			</section>

			<!-- Stack -->
			<section class="section section-dark">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-label">Standards-Based</p>
						<h2 class="section-title">Built on proven specifications, not proprietary protocols</h2>
					</div>
					<div class="stack-grid">
						<div class="stack-item">
							<p class="stack-name">C2PA</p>
							<p class="stack-desc">Content credentials</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">DIDs</p>
							<p class="stack-desc">Decentralized identity</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">VCs</p>
							<p class="stack-desc">Verifiable credentials</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">Cedar</p>
							<p class="stack-desc">Policy language</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">in-toto</p>
							<p class="stack-desc">Supply chain attestations</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">SLSA</p>
							<p class="stack-desc">Build provenance</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">SPIFFE</p>
							<p class="stack-desc">Workload identity</p>
						</div>
						<div class="stack-item">
							<p class="stack-name">DSSE</p>
							<p class="stack-desc">Signature envelopes</p>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="cta-section">
				<h2 class="cta-title">The PKI that PKI should have been. Built for agents, not browsers.</h2>
				<a href="/contact" class="hero-cta">Start a conversation →</a>
			</section>

			<!-- Footer -->
			<footer class="footer">
				<p class="footer-text">© 2026 Noosphere Technologies, Inc.</p>
				<div class="footer-links">
					<a href="/blog">Blog</a>
					<a href="/contact">Contact</a>
					<a href="https://github.com/noosphere-technologies">GitHub</a>
					<a href="https://twitter.com/noospheretech">Twitter</a>
				</div>
			</footer>
		</div>
	</body>
</html>
