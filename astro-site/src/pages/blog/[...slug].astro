---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: [post.id] },
	}));
}

type Props = CollectionEntry<'blog'>;

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam[slugParam.length - 1] : slugParam;

const post = (await getCollection('blog')).find((entry) => entry.id === slug);

if (!post) {
	return Astro.redirect('/blog');
}

const { Content } = await render(post);

// Get raw content for the AI assistant by reading the file directly
let rawContent = '';
try {
	const filePath = path.join(process.cwd(), 'src/content/blog', `${slug}.md`);
	const fileContent = fs.readFileSync(filePath, 'utf-8');
	// Remove frontmatter (everything between --- and ---)
	rawContent = fileContent.replace(/^---[\s\S]*?---\n*/, '');
} catch (e) {
	console.error('Could not read blog content:', e);
	rawContent = post.body || '';
}
---

<BlogPost {...post.data} slug={post.id} rawContent={rawContent}>
	<Content />
</BlogPost>
