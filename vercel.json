{
  "version": 2,
  "framework": "astro",
  "buildCommand": "cd astro-site && npm install && npm run build",
  "outputDirectory": "astro-site/.vercel/output",
  "installCommand": "cd astro-site && npm install",
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, HEAD, OPTIONS, POST"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "*"
        },
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    }
  ]
}
